@model DashboardViewModel
@{
    Layout = "_Layout";
    ViewData["Tittle"] = "Dashboard";
}
<div class="container-fluid">
    <div class="row mt-3 db-card">
        <div class="col col-6 col-sm-6 col-md-4 col-lg-3">
            Filtro por Programa
        </div>
        <div class="col col-6 col-sm-6 col-md-4 col-lg-3">
            Filtro por Año
        </div>
        <div class="col col-6 col-sm-6 col-md-4 col-lg-3">
            Filtro por Mes
        </div>
        <div class="col col-6 col-sm-6 col-md-4 col-lg-3">
            Filtro por Pago Cliente
        </div>
    </div>
    <div class="row mt-3 ">
        <div class="col-12 col-lg-3 col-md-3 col-sm-12 db-card">
            Periodo Actual VS Periodo Anterior
        </div>
        <div class="col-12 col-lg-9 col-md-9 col-sm-12 db-card">
            Tabla de los Programas
        </div>
    </div>
    <div class="row mt-3 ">
        <div class="col-12 db-card">
            Grafico de barras
        </div>
    </div>
    <div class="row mt-3 ">
        <div class="col-12 col-lg-10 col-md-10 col-sm-12 db-card">
            tabla personas
        </div>
        <div class="col-12 col-lg-2 col-md-2 col-sm -12 db-card">
            grafico torta estado pagos personas
        </div>
    </div>
</div>
